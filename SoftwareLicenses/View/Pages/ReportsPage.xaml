<UserControl x:Class="SoftwareLicenses.View.Pages.ReportsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:SoftwareLicenses.View.Pages"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <SolidColorBrush x:Key="TextPrimary" Color="#0F172A"/>
        <SolidColorBrush x:Key="TextMuted" Color="#64748B"/>
        <SolidColorBrush x:Key="BorderSoft" Color="#E5E7EB"/>
        <SolidColorBrush x:Key="CardBg" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="Accent" Color="#3B82F6"/>
        <SolidColorBrush x:Key="AccentHover" Color="#60A5FA"/>
        <DropShadowEffect x:Key="CardShadow" BlurRadius="24" ShadowDepth="10" Opacity="0.12"/>

        <!-- Buttons -->
        <Style x:Key="BtnSecondary" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Background" Value="#F1F5F9"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#EAF2FF"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#CFE0FF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource Accent}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TextBox for Days -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TextBox}">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#CFE0FF"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource Accent}"/>
                                <Setter TargetName="Bd" Property="BorderThickness" Value="1.4"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DataGrid -->
        <Style x:Key="ModernDataGrid" TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource CardBg}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#FAFBFF"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="RowHeight" Value="40"/>
            <Setter Property="ColumnHeaderHeight" Value="42"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderSoft}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="10,0"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EEF5FF"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#DDEBFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Page Card -->
        <Style x:Key="PageCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBg}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Effect" Value="{StaticResource CardShadow}"/>
        </Style>

        <!-- Inner Card -->
        <Style x:Key="InnerCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBg}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="12"/>
        </Style>

        <!-- Tabs (фикс “не в куче”) -->
        <!-- Tabs (нормальные вкладки в 1 ряд) -->
        <Style x:Key="ModernTabs" TargetType="TabControl">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Верхняя панель вкладок -->
                            <Border Background="#F8FAFC"
                            BorderBrush="{StaticResource BorderSoft}"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="8">
                                <!-- ВАЖНО: Orientation=Horizontal + ScrollViewer -->
                                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Disabled"
                                      CanContentScroll="True">
                                    <TabPanel IsItemsHost="True"
                               
                                      Margin="0"
                                      KeyboardNavigation.TabIndex="1"/>
                                </ScrollViewer>
                            </Border>

                            <!-- Контент выбранной вкладки -->
                            <ContentPresenter Grid.Row="1"
                                      Margin="0,12,0,0"
                                      ContentSource="SelectedContent"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernTabItem" TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Bd"
                        Background="#F1F5F9"
                        BorderBrush="{StaticResource BorderSoft}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"
                                      HorizontalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#EAF2FF"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#CFE0FF"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                            </Trigger>

                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#EAF2FF"/>
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Margin="0,0,0,12">
            <TextBlock Text="Отчёты"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimary}"
                       DockPanel.Dock="Left"/>

            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center">
                <TextBlock Text="Дней:"
                           Foreground="{StaticResource TextMuted}"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
                <TextBox Width="70"
                         Style="{StaticResource ModernTextBox}"
                         Text="{Binding Days, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,10,0"/>
                <Button Content="Сформировать"
                        Style="{StaticResource BtnPrimary}"
                        Command="{Binding BuildAllCommand}"/>
            </StackPanel>
        </DockPanel>

        <!-- Main Card -->
        <Border Grid.Row="1" Style="{StaticResource PageCard}">
            <TabControl Style="{StaticResource ModernTabs}">
                <!-- TAB 1 -->
                <TabItem Header="Истекающие">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Button Content="CSV"
                                    Style="{StaticResource BtnSecondary}"
                                    Command="{Binding ExportExpiringCsvCommand}"
                                    Margin="0,0,10,0"/>
                            <Button Content="Печать / PDF"
                                    Style="{StaticResource BtnSecondary}"
                                    Command="{Binding PrintExpiringCommand}"/>
                        </StackPanel>

                        <Border Grid.Row="1" Style="{StaticResource InnerCard}">
                            <DataGrid Style="{StaticResource ModernDataGrid}"
                                      ItemsSource="{Binding ExpiringLicenses}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ПО" Binding="{Binding Software}" Width="*"/>
                                    <DataGridTextColumn Header="Поставщик" Binding="{Binding Supplier}" Width="200"/>
                                    <DataGridTextColumn Header="Мест" Binding="{Binding Seats}" Width="70"/>
                                    <DataGridTextColumn Header="Занято" Binding="{Binding Used}" Width="70"/>
                                    <DataGridTextColumn Header="До" Binding="{Binding ExpireDate}" Width="110"/>
                                    <DataGridTextColumn Header="Ключ" Binding="{Binding KeyOrContract}" Width="220"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- TAB 2 -->
                <TabItem Header="Без лицензии">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Button Content="CSV"
                                    Style="{StaticResource BtnSecondary}"
                                    Command="{Binding ExportNoLicenseCsvCommand}"
                                    Margin="0,0,10,0"/>
                            <Button Content="Печать / PDF"
                                    Style="{StaticResource BtnSecondary}"
                                    Command="{Binding PrintNoLicenseCommand}"/>
                        </StackPanel>

                        <Border Grid.Row="1" Style="{StaticResource InnerCard}">
                            <DataGrid Style="{StaticResource ModernDataGrid}"
                                      ItemsSource="{Binding NoLicenseInstallations}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Инв№" Binding="{Binding DeviceInv}" Width="120"/>
                                    <DataGridTextColumn Header="Hostname" Binding="{Binding DeviceHost}" Width="160"/>
                                    <DataGridTextColumn Header="ПО" Binding="{Binding Software}" Width="*"/>
                                    <DataGridTextColumn Header="Дата" Binding="{Binding InstallDate}" Width="110"/>
                                    <DataGridTextColumn Header="Установил" Binding="{Binding InstalledBy}" Width="200"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- TAB 3 -->
                <TabItem Header="Использование">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Button Content="CSV"
                                    Style="{StaticResource BtnSecondary}"
                                    Command="{Binding ExportUsageCsvCommand}"
                                    Margin="0,0,10,0"/>
                            <Button Content="Печать / PDF"
                                    Style="{StaticResource BtnSecondary}"
                                    Command="{Binding PrintUsageCommand}"/>
                        </StackPanel>

                        <Border Grid.Row="1" Style="{StaticResource InnerCard}">
                            <DataGrid Style="{StaticResource ModernDataGrid}"
                                      ItemsSource="{Binding LicenseUsage}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ПО" Binding="{Binding Software}" Width="*"/>
                                    <DataGridTextColumn Header="Мест" Binding="{Binding Seats}" Width="70"/>
                                    <DataGridTextColumn Header="Занято" Binding="{Binding Used}" Width="70"/>
                                    <DataGridTextColumn Header="Больше" Binding="{Binding Over}" Width="70"/>
                                    <DataGridTextColumn Header="До" Binding="{Binding ExpireDate}" Width="110"/>
                                    <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="120"/>
                                    <DataGridTextColumn Header="Ключ" Binding="{Binding KeyOrContract}" Width="220"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Grid>
                </TabItem>
            </TabControl>
        </Border>
    </Grid>
</UserControl>
