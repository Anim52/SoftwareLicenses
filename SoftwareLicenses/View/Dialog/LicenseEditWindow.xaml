<Window x:Class="SoftwareLicenses.View.Dialog.LicenseEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SoftwareLicenses.View.Dialog"
        mc:Ignorable="d"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Title="{Binding Title}"
        Background="#0B1220"
        Foreground="#E5E7EB"
        FontFamily="Segoe UI"
        TextElement.FontSize="13"
        Icon="/Resources/Images/Image.ico">

    <Window.Resources>
        <!-- Палитра -->
        <SolidColorBrush x:Key="CardBg" Color="#121A2A"/>
        <SolidColorBrush x:Key="BorderSoft" Color="#263246"/>
        <SolidColorBrush x:Key="TextMuted" Color="#9CA3AF"/>
        <SolidColorBrush x:Key="Accent" Color="#3B82F6"/>
        <SolidColorBrush x:Key="AccentHover" Color="#60A5FA"/>

        <DropShadowEffect x:Key="CardShadow" BlurRadius="22" ShadowDepth="8" Opacity="0.35"/>

        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="Margin" Value="2,0,0,6"/>
        </Style>

        <!-- ✅ ModernTextBox прямо в окне (как просил) -->
        <Style x:Key="ModernTextBox" TargetType="{x:Type TextBox}">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Background" Value="#0F172A"/>
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CaretBrush" Value="#E5E7EB"/>
            <Setter Property="SelectionBrush" Value="#334155"/>
            <Setter Property="SelectionOpacity" Value="0.9"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="UseLayoutRounding" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TextBox}">
                        <Grid>
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="12"/>
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#3A4A68"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource Accent}"/>
                                <Setter TargetName="Bd" Property="BorderThickness" Value="1.4"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Многострочный вариант -->
        <Style x:Key="ModernTextBoxMulti" TargetType="TextBox" BasedOn="{StaticResource ModernTextBox}">
            <Setter Property="Height" Value="86"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="VerticalContentAlignment" Value="Top"/>
            <Setter Property="Padding" Value="12,10"/>
        </Style>

        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Background" Value="#0F172A"/>
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="ModernDatePicker" TargetType="DatePicker">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Background" Value="#0F172A"/>
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="BtnSecondary" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="Background" Value="#17233A"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource Accent}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Border Background="{StaticResource CardBg}"
                BorderBrush="{StaticResource BorderSoft}"
                BorderThickness="1"
                CornerRadius="18"
                Padding="18"
                Effect="{StaticResource CardShadow}">

            <Grid Width="520">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- header -->
                    <RowDefinition Height="Auto"/>
                    <!-- ПО -->
                    <RowDefinition Height="Auto"/>
                    <!-- Тип+Статус -->
                    <RowDefinition Height="Auto"/>
                    <!-- Ключ -->
                    <RowDefinition Height="Auto"/>
                    <!-- Поставщик -->
                    <RowDefinition Height="Auto"/>
                    <!-- Seats+Cost -->
                    <RowDefinition Height="Auto"/>
                    <!-- Даты -->
                    <RowDefinition Height="Auto"/>
                    <!-- Notes -->
                    <RowDefinition Height="Auto"/>
                    <!-- Buttons -->
                </Grid.RowDefinitions>

                <!-- Header -->
                <StackPanel Grid.Row="0" Margin="0,0,0,14">
                    <TextBlock Text="{Binding Title}" FontSize="18" FontWeight="SemiBold"/>
                    <TextBlock Text="Параметры лицензии и условия использования"
                               Foreground="{StaticResource TextMuted}"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <!-- ПО -->
                <StackPanel Grid.Row="1">
                    <TextBlock Style="{StaticResource LabelText}" Text="Программное обеспечение"/>
                    <ComboBox Style="{StaticResource ModernComboBox}"
                              ItemsSource="{Binding Softwares}"
                              SelectedItem="{Binding SelectedSoftware}"
                              DisplayMemberPath="Name"/>
                </StackPanel>

                <!-- Тип + Статус -->
                <Grid Grid.Row="2" Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Style="{StaticResource LabelText}" Text="Тип лицензии"/>
                        <ComboBox Style="{StaticResource ModernComboBox}"
                                  ItemsSource="{Binding LicenseTypes}"
                                  SelectedItem="{Binding Type}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Style="{StaticResource LabelText}" Text="Статус"/>
                        <ComboBox Style="{StaticResource ModernComboBox}"
                                  ItemsSource="{Binding LicenseStatuses}"
                                  SelectedItem="{Binding Status}"/>
                    </StackPanel>
                </Grid>

                <!-- Ключ/договор -->
                <StackPanel Grid.Row="3" Margin="0,12,0,0">
                    <TextBlock Style="{StaticResource LabelText}" Text="Ключ / Договор"/>
                    <TextBox Style="{StaticResource ModernTextBox}"
                             Text="{Binding KeyOrContract, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <!-- Поставщик -->
                <StackPanel Grid.Row="4" Margin="0,12,0,0">
                    <TextBlock Style="{StaticResource LabelText}" Text="Поставщик (опц.)"/>
                    <ComboBox Style="{StaticResource ModernComboBox}"
                              ItemsSource="{Binding Suppliers}"
                              SelectedItem="{Binding SelectedSupplier}"
                              DisplayMemberPath="Name"/>
                </StackPanel>

                <!-- Seats + Cost -->
                <Grid Grid.Row="5" Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Style="{StaticResource LabelText}" Text="Кол-во мест"/>
                        <TextBox Style="{StaticResource ModernTextBox}"
                                 Text="{Binding Seats, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Style="{StaticResource LabelText}" Text="Стоимость (опц.)"/>
                        <TextBox Style="{StaticResource ModernTextBox}"
                                 Text="{Binding Cost, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </Grid>

                <!-- Даты -->
                <Grid Grid.Row="6" Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Style="{StaticResource LabelText}" Text="Дата покупки"/>
                        <DatePicker Style="{StaticResource ModernDatePicker}"
                                    SelectedDate="{Binding PurchaseDate}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Style="{StaticResource LabelText}" Text="Дата окончания (опц.)"/>
                        <DatePicker Style="{StaticResource ModernDatePicker}"
                                    SelectedDate="{Binding ExpireDate}"/>
                    </StackPanel>
                </Grid>

                <!-- Notes -->
                <StackPanel Grid.Row="7" Margin="0,12,0,0">
                    <TextBlock Style="{StaticResource LabelText}" Text="Примечание"/>
                    <TextBox Style="{StaticResource ModernTextBoxMulti}"
                             Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <!-- Buttons -->
                <StackPanel Grid.Row="8"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,16,0,0">
                    <Button Content="Отмена"
                            Style="{StaticResource BtnSecondary}"
                            Command="{Binding CancelCommand}"
                            Margin="0,0,10,0"/>
                    <Button Content="Сохранить"
                            Style="{StaticResource BtnPrimary}"
                            Command="{Binding SaveCommand}"/>
                </StackPanel>

            </Grid>
        </Border>
    </Grid>
</Window>
