<Window x:Class="SoftwareLicenses.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SoftwareLicenses"
        xmlns:vmDash="clr-namespace:SoftwareLicenses.ViewModels.Dashboard"
        xmlns:vmSoft="clr-namespace:SoftwareLicenses.ViewModels.Softwares"
        xmlns:vmLic="clr-namespace:SoftwareLicenses.ViewModels.Licenses"
        xmlns:vmDev="clr-namespace:SoftwareLicenses.ViewModels.Devices"
        xmlns:vmInst="clr-namespace:SoftwareLicenses.ViewModels.Installations"
        xmlns:vmEmp="clr-namespace:SoftwareLicenses.ViewModels.Employees"
        xmlns:vmSup="clr-namespace:SoftwareLicenses.ViewModels.Suppliers"
        xmlns:views="clr-namespace:SoftwareLicenses.View.Pages"
        xmlns:vmUsers="clr-namespace:SoftwareLicenses.ViewModels.Users"
        xmlns:vmRep="clr-namespace:SoftwareLicenses.ViewModels.Reports"
        xmlns:conv="clr-namespace:SoftwareLicenses.Converters"
        mc:Ignorable="d"
        Title="Учёт ПО и лицензий — ИП Лозовая Н.Н."
        Width="1300"
        Height="760"
        WindowStartupLocation="CenterScreen"
        Background="#F3F4F6"
        FontFamily="Segoe UI"
        TextElement.FontSize="13"
        Icon="/Resources/Images/Image.ico">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>

        <!-- ====== Pages mapping (как было) ====== -->
        <DataTemplate DataType="{x:Type vmRep:ReportsPageViewModel}">
            <views:ReportsPage/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vmUsers:AccountsPageViewModel}">
            <views:AccountsPage/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vmDash:DashboardViewModel}">
            <views:DashboardPage/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vmSoft:SoftwaresPageViewModel}">
            <views:SoftwaresPage/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vmLic:LicensesPageViewModel}">
            <views:LicensesPage/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vmDev:DevicesPageViewModel}">
            <views:DevicesPage/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vmInst:InstallationsPageViewModel}">
            <views:InstallationsPage/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vmEmp:EmployeesPageViewModel}">
            <views:EmployeesPage/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vmSup:SuppliersPageViewModel}">
            <views:SuppliersPage/>
        </DataTemplate>

        <!-- ====== Colors ====== -->
        <SolidColorBrush x:Key="SidebarBg" Color="#F3F4F6"/>
        <SolidColorBrush x:Key="SidebarBorder" Color="#1F2A3D"/>
        <SolidColorBrush x:Key="ContentBg" Color="#F5F7FB"/>
        <SolidColorBrush x:Key="CardBg" Color="#1F2937"/>

        <SolidColorBrush x:Key="TextOnDark" Color="#1F2937"/>
        <SolidColorBrush x:Key="TextMutedOnDark" Color="#6B7280"/>

        <SolidColorBrush x:Key="Accent" Color="#374151"/>
        <SolidColorBrush x:Key="AccentHover" Color="#4B5563"/>

        <DropShadowEffect x:Key="CardShadow" BlurRadius="24" ShadowDepth="10" Opacity="0.18"/>

        <!-- ====== Sidebar Button ====== -->
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Margin" Value="10,4"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextOnDark}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="4"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- акцентная полоска слева -->
                                <Border x:Name="AccentBar"
                                        Grid.Column="0"
                                        Background="Transparent"
                                        CornerRadius="10"/>

                                <ContentPresenter Grid.Column="1"
                                                  Margin="10,0,0,0"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                            </Grid>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#16233A"/>
                                <Setter TargetName="AccentBar" Property="Background" Value="{StaticResource AccentHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1A2A45"/>
                                <Setter TargetName="AccentBar" Property="Background" Value="{StaticResource Accent}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Divider -->
        <Style TargetType="Separator">
            <Setter Property="Margin" Value="12,10"/>
            <Setter Property="Background" Value="#243146"/>
            <Setter Property="Height" Value="1"/>
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True">

        <!-- ===== Sidebar ===== -->
        <Border DockPanel.Dock="Left"
                Width="260"
                Background="{StaticResource SidebarBg}"
                BorderBrush="{StaticResource SidebarBorder}"
                BorderThickness="0,0,1,0">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <StackPanel Grid.Row="0" Margin="16,16,16,10">
                    <TextBlock Text="ИС учёта ПО"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextOnDark}"/>
                    <TextBlock Text="и лицензий"
                               Margin="0,2,0,0"
                               Foreground="{StaticResource TextMutedOnDark}"/>
                </StackPanel>

                <!-- Menu -->
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="6,0,6,10">

                        <Button Content="🏠  Дашборд"
                                Style="{StaticResource NavButton}"
                                Command="{Binding OpenDashboardCommand}"/>

                        <Separator/>

                        <Button Content="💻  ПО"
                                Style="{StaticResource NavButton}"
                                Command="{Binding OpenSoftwaresCommand}"/>

                        <Button Content="🔑  Лицензии"
                                Style="{StaticResource NavButton}"
                                Command="{Binding OpenLicensesCommand}"/>

                        <Button Content="🖥  Устройства"
                                Style="{StaticResource NavButton}"
                                Command="{Binding OpenDevicesCommand}"/>

                        <Button Content="⚙  Установки"
                                Style="{StaticResource NavButton}"
                                Command="{Binding OpenInstallationsCommand}"/>

                        <Separator/>

                        <Button Content="👤  Сотрудники"
                                Style="{StaticResource NavButton}"
                                Command="{Binding OpenEmployeesCommand}"/>

                        <Button Content="👥  Пользователи"
                                Style="{StaticResource NavButton}"
                                Command="{Binding OpenUsersCommand}"
                                Visibility="{Binding CanManageUsers, Converter={StaticResource BoolToVis}}"/>

                        <Button Content="🏢  Поставщики"
                                Style="{StaticResource NavButton}"
                                Command="{Binding OpenSuppliersCommand}"/>

                        <Button Content="📄  Отчёты"
                                Style="{StaticResource NavButton}"
                                Command="{Binding OpenReportsCommand}"
                                Visibility="{Binding CanSeeReports, Converter={StaticResource BoolToVis}}"/>

                    </StackPanel>
                </ScrollViewer>

                <!-- Footer hint (не мешает логике) -->
                <TextBlock Grid.Row="2"
                           Text="© Учёт ПО • WPF"
                           Foreground="{StaticResource TextMutedOnDark}"
                           Margin="16,10,16,14"/>
            </Grid>
        </Border>

        <!-- ===== Content ===== -->
        <Border Background="{StaticResource ContentBg}" Padding="16">
            <Border Background="{StaticResource CardBg}"
                    CornerRadius="10"
                    Padding="16"
                    Effect="{StaticResource CardShadow}">
                <ContentControl Content="{Binding CurrentVm}"/>
            </Border>
        </Border>

    </DockPanel>
</Window>
